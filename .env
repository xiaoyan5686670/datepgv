DATABASE_URL=postgresql+asyncpg://datepgv:datepgv123@localhost:5432/datepgv

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
