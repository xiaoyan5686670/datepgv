# Backend: PostgreSQL used by the app + (by default) NL→SQL execute target if ANALYTICS_POSTGRES_URL is unset
POSTGRES_USER=datepgv
POSTGRES_PASSWORD=datepgv123
POSTGRES_DB=datepgv
DATABASE_URL=postgresql+asyncpg://datepgv:datepgv123@localhost:5432/datepgv

# Optional: override execute target only (otherwise same DB as DATABASE_URL is used for PostgreSQL).
# You can instead configure execute DB URLs in the web UI: Settings → 数据连接.
#ANALYTICS_POSTGRES_URL=postgresql://readonly:secret@localhost:5432/analytics
# MySQL execute (no default from DATABASE_URL) — optional if set in UI
#ANALYTICS_MYSQL_URL=mysql://user:pass@localhost:3306/dbname
#ANALYTICS_QUERY_TIMEOUT_SEC=30
#ANALYTICS_MAX_ROWS=500
#ANALYTICS_MAX_CELL_CHARS=2000

DEBUG=false

# Frontend needs no API URL in .env: it calls /api/backend → Next proxies to FastAPI (127.0.0.1:8000).
# Docker Compose sets BACKEND_URL on the frontend service in docker-compose.yml.

# Optional: Ollama when LLM config leaves API Base empty
#OLLAMA_API_BASE=http://host.docker.internal:11434

# LLM / embedding providers are configured in the web UI at /settings.
